body {
  font-family: Arial;
  background: #111;
  color: white;
  text-align: center;
}

#uploadBox {
  padding: 10px;
  background: #222;
  margin: 10px;
}

#feed {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.post {
  background: #1e1e1e;
  margin: 10px;
  padding: 10px;
  width: 300px;
  border-radius: 10px;
}

img, video {
  width: 100%;
  border-radius: 10px;
}

button {
  margin-top: 5px;
}
